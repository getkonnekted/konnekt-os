rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Catch-all Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Schema Validations ---
    function isValidUserProfile(data) {
      return data.keys().hasAll(['handle', 'intent', 'ownerId', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 20
        && data.handle is string && data.handle.size() >= 3 && data.handle.size() <= 32
        && data.intent in ['SERVICE', 'COMMERCE', 'CORPORATE', 'CREATOR']
        && data.ownerId is string && data.ownerId == request.auth.uid
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && (data.bio == null || (data.bio is string && data.bio.size() <= 500))
        && (data.theme == null || data.theme in ['DARK', 'LIGHT', 'BRAND', 'MINIMAL'])
        && (data.primaryCTAText == null || (data.primaryCTAText is string && data.primaryCTAText.size() <= 50))
        && (data.primaryCTAUrl == null || (data.primaryCTAUrl is string && data.primaryCTAUrl.size() <= 500))
        && (data.customCTAText == null || (data.customCTAText is string && data.customCTAText.size() <= 50))
        && (data.customCTAUrl == null || (data.customCTAUrl is string && data.customCTAUrl.size() <= 500))
        && (data.instagram == null || (data.instagram is string && data.instagram.size() <= 100))
        && (data.linkedin == null || (data.linkedin is string && data.linkedin.size() <= 100));
    }

    function isValidAnalyticsEvent(data) {
      return data.keys().hasAll(['userId', 'type', 'timestamp'])
        && data.keys().size() <= 10
        && data.userId is string
        && data.type in ['view', 'action']
        && data.timestamp == request.time;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'timestamp'])
        && data.keys().size() <= 10
        && data.name is string && data.name.size() <= 100
        && data.timestamp == request.time;
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['planId', 'status'])
        && data.planId in ['FREE', 'PRO', 'BUSINESS'];
    }

    function isValidTwoFactorAuth(data) {
      return data.keys().hasAll(['enabled'])
        && data.enabled is bool;
    }

    // --- Rules ---

    // Users (Private Data)
    match /users/{userId} {
      match /private/billing {
        allow read: if isOwner(userId);
        allow write: if false; // System only
      }
      match /private/security {
        allow read: if isOwner(userId);
        allow write: if false; // System only
      }
    }

    // Profiles
    match /profiles/{profileId} {
      allow get, list: if true; // Public profiles
      allow create: if isSignedIn() 
                    && isValidId(profileId) 
                    && isValidUserProfile(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      allow update: if isSignedIn() 
                    && isOwner(existing().ownerId)
                    && isValidUserProfile(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().ownerId == existing().ownerId
                    && incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && isOwner(existing().ownerId);

      // Links (Master Gate)
      match /links/{linkId} {
        allow read: if true;
        allow write: if isSignedIn() 
                     && get(/databases/$(database)/documents/profiles/$(profileId)).data.ownerId == request.auth.uid;
      }

      // Leads (Master Gate)
      match /leads/{leadId} {
        allow get, list: if isSignedIn() 
                          && get(/databases/$(database)/documents/profiles/$(profileId)).data.ownerId == request.auth.uid;
        allow create: if isValidLead(incoming()); // Guests can submit leads
      }
    }

    // Analytics
    match /analytics/{eventId} {
      allow create: if isValidAnalyticsEvent(incoming());
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
